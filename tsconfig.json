{
"compilerOptions": {
    "composite": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "paths": {
        "@/*": ["./src/*"]
    },
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,
    "allowJs": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "preserve",
    "types": ["node"]
},
"include": ["env.d.ts", "src/**/*", "src/**/*.vue"]
}